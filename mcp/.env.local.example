# Local-only MCP config. Copy to mcp/.env.local and fill in values.
DULLY_MCP_ENV=dev
DULLY_MCP_API_BASE_URL=http://localhost:8000
DULLY_MCP_OPENAPI_URL=http://localhost:8000/openapi.json
DULLY_MCP_FRONTEND_URL=http://localhost:5173
OPENAI_API_KEY=your-openai-key
DULLY_MCP_FIREBASE_API_KEY=your-firebase-web-api-key
DULLY_MCP_FIREBASE_EMAIL=justin@ttcommercial.com
DULLY_MCP_FIREBASE_PASSWORD=change_me
DULLY_MCP_ALLOW_WRITE=0
DULLY_MCP_ALLOWLIST_MODE=auto
DULLY_MCP_ALLOWLIST_FILE=mcp/allowlist.prod.json
