{
  "name": "sandbox-ui",
  "private": true,
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "echo 'Use npm run build:dev or npm run build:prod.' && exit 1",
    "build:raw": "tsc -b && vite build",
    "build:dev": "bash ../scripts/use-frontend-env.sh dev && npm run build:raw",
    "build:prod": "bash ../scripts/use-frontend-env.sh prod && npm run build:raw",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "10.12.5",
    "firebaseui": "^6.1.0",
    "pdfjs-dist": "^4.5.136",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "read-excel-file": "^6.0.3"
  },
  "overrides": {
    "undici": "6.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
