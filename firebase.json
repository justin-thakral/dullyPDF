{
  "firestore": {
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "frontend/dist",
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/privacy-policy",
        "destination": "/privacy",
        "type": 301
      },
      {
        "source": "/terms-of-service",
        "destination": "/terms",
        "type": 301
      },
      {
        "source": "/docs",
        "destination": "/usage-docs",
        "type": 301
      },
      {
        "source": "/docs/:slug*",
        "destination": "/usage-docs/:slug",
        "type": 301
      },
      {
        "source": "/insurance-acord-form-automation",
        "destination": "/acord-form-automation",
        "type": 301
      },
      {
        "source": "/insurance-form-automation",
        "destination": "/insurance-pdf-automation",
        "type": 301
      },
      {
        "source": "/insurance-pdf-form-automation",
        "destination": "/insurance-pdf-automation",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'self'; object-src 'none'; form-action 'self'; script-src 'self' https://www.googletagmanager.com https://www.google.com https://www.gstatic.com https://apis.google.com https://googleads.g.doubleclick.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https: wss:; frame-src 'self' blob: https://www.google.com https://recaptcha.google.com https://dullypdf.firebaseapp.com https://www.youtube-nocookie.com https://www.youtube.com; worker-src 'self' blob:; media-src 'self' data: blob: https:"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/respond/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store,max-age=0"
          }
        ]
      },
      {
        "source": "/sign/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store,max-age=0"
          }
        ]
      },
      {
        "source": "/demo/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDFLogoImproved.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDFLogoImproved.webp",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDF.webp",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDF-logo.svg",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDF.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/favicon.ico",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/account-action",
        "destination": "/app-shell.html"
      },
      {
        "source": "/verify-email",
        "destination": "/app-shell.html"
      },
      {
        "source": "/upload",
        "destination": "/app-shell.html"
      },
      {
        "source": "/ui",
        "destination": "/app-shell.html"
      },
      {
        "source": "/ui/profile",
        "destination": "/app-shell.html"
      },
      {
        "source": "/ui/forms/:formId",
        "destination": "/app-shell.html"
      },
      {
        "source": "/ui/groups/:groupId",
        "destination": "/app-shell.html"
      },
      {
        "source": "/respond/:token",
        "destination": "/app-shell.html"
      },
      {
        "source": "/sign/:token",
        "destination": "/app-shell.html"
      },
      {
        "source": "/verify-signing/:token",
        "destination": "/app-shell.html"
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "dullypdf-backend-east4",
          "region": "us-east4"
        }
      },
      {
        "source": "/api",
        "run": {
          "serviceId": "dullypdf-backend-east4",
          "region": "us-east4"
        }
      },
      {
        "source": "/detect-fields",
        "run": {
          "serviceId": "dullypdf-backend-east4",
          "region": "us-east4"
        }
      },
      {
        "source": "/detect-fields/**",
        "run": {
          "serviceId": "dullypdf-backend-east4",
          "region": "us-east4"
        }
      }
    ]
  }
}
