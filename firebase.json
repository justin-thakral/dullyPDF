{
  "hosting": {
    "public": "frontend/dist",
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/privacy-policy",
        "destination": "/privacy",
        "type": 301
      },
      {
        "source": "/terms-of-service",
        "destination": "/terms",
        "type": 301
      },
      {
        "source": "/docs",
        "destination": "/usage-docs",
        "type": 301
      },
      {
        "source": "/docs/:slug*",
        "destination": "/usage-docs/:slug",
        "type": 301
      },
      {
        "source": "/insurance-acord-form-automation",
        "destination": "/acord-form-automation",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/demo/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDFLogoImproved.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDFLogoImproved.webp",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDF.webp",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDF-logo.svg",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/DullyPDF.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/favicon.ico",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/health",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/recaptcha/assess",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/contact",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/profile",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/billing/checkout-session",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/billing/subscription/cancel",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/billing/reconcile",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/billing/webhook-health",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/schemas",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/sessions/*/touch",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/saved-forms",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/saved-forms/*",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/saved-forms/*/session",
        "run": {
          "serviceId": "dullypdf-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
