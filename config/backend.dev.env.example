# Backend (dev/local)
ENV=dev
PORT=8000

# Security + limits
# The backend also appends a built-in localhost/127.0.0.1 Vite range (5173-5189)
# outside production so local port bumps keep working during multi-terminal dev.
SANDBOX_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176
SANDBOX_MAX_UPLOAD_MB=50
SANDBOX_DETECT_MAX_PAGES_BASE=5
SANDBOX_DETECT_MAX_PAGES_PRO=100
SANDBOX_DETECT_MAX_PAGES_GOD=100
SANDBOX_FILLABLE_MAX_PAGES_BASE=50
SANDBOX_FILLABLE_MAX_PAGES_PRO=1000
SANDBOX_FILLABLE_MAX_PAGES_GOD=1000
SANDBOX_SIGNING_REQUESTS_PER_DOCUMENT_MAX_BASE=10
SANDBOX_SIGNING_REQUESTS_PER_DOCUMENT_MAX_PRO=1000
SANDBOX_SIGNING_REQUESTS_PER_DOCUMENT_MAX_GOD=100000
SANDBOX_SAVED_FORMS_MAX_BASE=3
SANDBOX_SAVED_FORMS_MAX_PRO=20
SANDBOX_SAVED_FORMS_MAX_GOD=20
SANDBOX_SESSION_TTL_SECONDS=7200
SANDBOX_SCHEMA_TTL_SECONDS=3600
SANDBOX_SESSION_SWEEP_INTERVAL_SECONDS=300
SANDBOX_SESSION_MAX_ENTRIES=200
SANDBOX_SESSION_L2_TOUCH_SECONDS=300
SANDBOX_RATE_LIMIT_BACKEND=firestore
SANDBOX_RATE_LIMIT_COLLECTION=rate_limits
SANDBOX_DETECT_RATE_LIMIT_WINDOW_SECONDS=30
SANDBOX_DETECT_RATE_LIMIT_PER_USER=6
# Legacy sandbox endpoints (dev only; defaults to true when unset).
SANDBOX_ENABLE_LEGACY_ENDPOINTS=true

# Contact form
CONTACT_TO_EMAIL=contact@example.com
CONTACT_FROM_EMAIL=contact@example.com
# Signing invites default to CONTACT_FROM_EMAIL when unset, but keep these
# explicit in dev so copied links point at the intended frontend host.
SIGNING_FROM_EMAIL=contact@example.com
SIGNING_APP_ORIGIN=http://localhost:5173
SIGNING_LINK_TOKEN_SECRET=change_me_dev_signing_token_secret
SIGNING_BUCKET=dullypdf-dev-signing
# Optional embedded PDF digital signature for local validation testing.
# Leave the bundled dev certificate disabled unless you explicitly want
# completed local PDFs to carry a cryptographic signature.
SIGNING_PDF_USE_BUNDLED_DEV_CERT=false
# SIGNING_PDF_P12_PATH=/path/to/local-signing-cert.p12
# SIGNING_PDF_P12_PASSWORD=change_me
# SIGNING_PDF_TSA_URL=https://tsa.example.com
# Optional short-lived staging tier for pre-finalization uploads. When unset the
# backend falls back to the session bucket, then FORMS_BUCKET.
# SIGNING_STAGING_BUCKET=dullypdf-dev-signing-staging
SIGNING_REQUEST_TTL_DAYS=30
SIGNING_VERIFICATION_SOURCE_TYPES=workspace,fill_link_response,uploaded_pdf
SIGNING_ARTIFACT_TOKEN_TTL_SECONDS=300
FILL_LINK_SIGNING_RESEND_COOLDOWN_SECONDS=300
# Optional best-effort server-to-server signing lifecycle webhooks.
# SIGNING_WEBHOOK_URL=http://localhost:9000/hooks/signing
# SIGNING_WEBHOOK_URLS=http://localhost:9000/hooks/signing,https://example.com/hooks/signing
# SIGNING_WEBHOOK_SECRET=change_me_dev_signing_webhook_secret
# SIGNING_WEBHOOK_TIMEOUT_SECONDS=8
# SIGNING_WEBHOOK_EVENT_TYPES=request_created,request_sent,invite_sent,opened,review_confirmed,consent_accepted,completed,link_revoked,link_reissued
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Optional Secret Manager bindings for local/dev when you want to reuse a
# shared sender without storing the Gmail secret/refresh token in this file.
GMAIL_CLIENT_SECRET_SECRET=
GMAIL_REFRESH_TOKEN_SECRET=
GMAIL_SECRETS_PROJECT=
# Defaults to "me".
GMAIL_USER_ID=
RECAPTCHA_SITE_KEY=
# Defaults to FIREBASE_PROJECT_ID when omitted.
RECAPTCHA_PROJECT_ID=
RECAPTCHA_CONTACT_ACTION=contact
RECAPTCHA_SIGNUP_ACTION=signup
# Optional allowlist for reCAPTCHA token hostnames (comma-separated, supports *.example.com).
RECAPTCHA_ALLOWED_HOSTNAMES=
RECAPTCHA_MIN_SCORE=0.5
CONTACT_REQUIRE_RECAPTCHA=true
SIGNUP_REQUIRE_RECAPTCHA=true
FILL_LINK_REQUIRE_RECAPTCHA=true
FILL_LINK_TOKEN_SECRET=change_me_dev_fill_link_token_secret
FILL_LINK_VIEW_RATE_WINDOW_SECONDS=60
FILL_LINK_VIEW_RATE_PER_IP=60
FILL_LINK_SUBMIT_RATE_WINDOW_SECONDS=300
FILL_LINK_SUBMIT_RATE_PER_IP=20
FILL_LINK_DOWNLOAD_RATE_WINDOW_SECONDS=300
FILL_LINK_DOWNLOAD_RATE_PER_IP=20
FILL_LINK_MAX_ANSWER_VALUE_CHARS=500
FILL_LINK_MAX_TOTAL_ANSWER_CHARS=4000
FILL_LINK_MAX_MULTI_SELECT_VALUES=25
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
CONTACT_RATE_LIMIT_PER_IP=6
SIGNUP_RATE_LIMIT_WINDOW_SECONDS=600
SIGNUP_RATE_LIMIT_PER_IP=8
SANDBOX_TRUST_PROXY_HEADERS=false

# Detector service (dev/local)
# DETECTOR_MODE=local requires backend/requirements-detector.txt (CommonForms).
# Use DETECTOR_MODE=tasks when running the detector service separately.
DETECTOR_MODE=local
# Set these when using Cloud Tasks + detector service locally.
DETECTOR_TASKS_PROJECT=
DETECTOR_TASKS_LOCATION=
DETECTOR_TASKS_QUEUE=
DETECTOR_SERVICE_URL=
DETECTOR_TASKS_SERVICE_ACCOUNT=
DETECTOR_TASKS_AUDIENCE=
DETECTOR_TASKS_DISPATCH_DEADLINE_SECONDS=1800
# CommonForms weights: prefer GCS in dev to avoid Hugging Face rate-limit fallback.
COMMONFORMS_MODEL=FFDNet-L
COMMONFORMS_MODEL_GCS_URI=gs://dullypdf-dev-models/commonforms/FFDNet-L.pt

# Admin override (optional)
ADMIN_TOKEN=

# Firebase Admin
FIREBASE_PROJECT_ID=dullypdf-dev
# Optional revocation checks in dev.
FIREBASE_CHECK_REVOKED=false
# Prefer Secret Manager for local/dev; scripts load this into FIREBASE_CREDENTIALS.
FIREBASE_CREDENTIALS_SECRET=dullypdf-dev-firebase-admin
FIREBASE_CREDENTIALS_PROJECT=dullypdf-dev
# Firebase OAuth providers (reference only)
FIREBASE_GITHUB_CLIENT_ID=
FIREBASE_GITHUB_CLIENT_SECRET=
FIREBASE_GOOGLE_CLIENT_ID=
FIREBASE_GOOGLE_CLIENT_SECRET=
# Preferred local dev path: keep this unset, run `gcloud auth application-default login`,
# and let scripts/_load_firebase_secret.sh fetch Firebase Admin credentials from Secret Manager.
# Optional local key file fallback:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/dullypdf-dev-service-account.json

# Storage buckets
FORMS_BUCKET=dullypdf-dev-forms
TEMPLATES_BUCKET=dullypdf-dev-templates
SANDBOX_SESSION_BUCKET=dullypdf-dev-sessions

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_SCHEMA_MAPPING_MODEL=gpt-5.2
SANDBOX_RENAME_MODEL=gpt-5.2
OPENAI_SCHEMA_MAX_FIELDS=200
OPENAI_TEMPLATE_MAX_FIELDS=200
OPENAI_SCHEMA_MAX_PAYLOAD_BYTES=80000
OPENAI_SCHEMA_MAX_FIELD_NAME_LEN=120
OPENAI_SCHEMA_RATE_LIMIT_WINDOW_SECONDS=60
OPENAI_SCHEMA_RATE_LIMIT_PER_USER=10
OPENAI_RENAME_RATE_LIMIT_WINDOW_SECONDS=60
OPENAI_RENAME_RATE_LIMIT_PER_USER=6
BASE_OPENAI_CREDITS=10
PRO_MONTHLY_OPENAI_CREDITS=500
# Credit refund retries/reconciliation for rename/remap failures.
OPENAI_CREDIT_REFUND_MAX_ATTEMPTS=3
OPENAI_CREDIT_REFUND_RETRY_BACKOFF_MS=150
SANDBOX_OPENAI_LOG_TTL_SECONDS=2592000

# Stripe billing (dev/test only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_REFILL_500=
STRIPE_REFILL_CREDITS=500
# Optional for local Stripe CLI forwarding; required if webhook health enforcement stays enabled.
STRIPE_WEBHOOK_ENDPOINT_URL=http://localhost:8000/api/billing/webhook
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/?billing=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/?billing=cancel
# Local `npm run dev` Stripe CLI forwarding controls.
STRIPE_DEV_LISTEN_ENABLED=true
# STRIPE_DEV_FORWARD_URL=http://localhost:8000/api/billing/webhook
# STRIPE_DEV_FORWARD_EVENTS=checkout.session.completed,invoice.paid,customer.subscription.updated,customer.subscription.deleted

# Debug/logging
SANDBOX_DEBUG=false
SANDBOX_DEBUG_PASSWORD=
SANDBOX_DEBUG_FORCE=false
SANDBOX_LOG_OPENAI_RESPONSE=false
