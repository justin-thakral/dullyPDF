# Backend (dev stack; Cloud Tasks + Cloud Run detector; prod-mode backend)
ENV=prod
PORT=8000
# Dev stack bind address (default 127.0.0.1). Set to 0.0.0.0 only if needed.
DEV_STACK_BIND_ADDRESS=127.0.0.1

# Security + limits
SANDBOX_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176
SANDBOX_MAX_UPLOAD_MB=50
SANDBOX_DETECT_MAX_PAGES_BASE=5
SANDBOX_DETECT_MAX_PAGES_PRO=100
SANDBOX_DETECT_MAX_PAGES_GOD=100
SANDBOX_FILLABLE_MAX_PAGES_BASE=50
SANDBOX_FILLABLE_MAX_PAGES_PRO=1000
SANDBOX_FILLABLE_MAX_PAGES_GOD=1000
SANDBOX_SAVED_FORMS_MAX_BASE=3
SANDBOX_SAVED_FORMS_MAX_PRO=20
SANDBOX_SAVED_FORMS_MAX_GOD=20
SANDBOX_SESSION_TTL_SECONDS=7200
SANDBOX_SCHEMA_TTL_SECONDS=3600
SANDBOX_SESSION_SWEEP_INTERVAL_SECONDS=300
SANDBOX_SESSION_MAX_ENTRIES=200
SANDBOX_SESSION_L2_TOUCH_SECONDS=300
SANDBOX_RATE_LIMIT_BACKEND=firestore
SANDBOX_RATE_LIMIT_COLLECTION=rate_limits
SANDBOX_DETECT_RATE_LIMIT_WINDOW_SECONDS=30
SANDBOX_DETECT_RATE_LIMIT_PER_USER=6
# Legacy sandbox endpoints (dev only; keep false for prod-like behavior).
SANDBOX_ENABLE_LEGACY_ENDPOINTS=false

# Contact form
CONTACT_TO_EMAIL=dullymain@gmail.com
CONTACT_FROM_EMAIL=dullymain@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Defaults to "me".
GMAIL_USER_ID=
RECAPTCHA_SITE_KEY=
# Defaults to FIREBASE_PROJECT_ID when omitted.
RECAPTCHA_PROJECT_ID=
RECAPTCHA_MIN_SCORE=0.5
CONTACT_REQUIRE_RECAPTCHA=true
SIGNUP_REQUIRE_RECAPTCHA=true
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
CONTACT_RATE_LIMIT_PER_IP=6
SIGNUP_RATE_LIMIT_WINDOW_SECONDS=600
SIGNUP_RATE_LIMIT_PER_IP=8

# Detector service (dev via Cloud Tasks)
DETECTOR_MODE=tasks
DETECTOR_TASKS_PROJECT=dullypdf-dev
DETECTOR_TASKS_LOCATION=us-central1
DETECTOR_TASKS_QUEUE=commonforms-detect-light
DETECTOR_SERVICE_URL=https://dullypdf-detector-light-xxxxx-uc.a.run.app
DETECTOR_TASKS_QUEUE_LIGHT=commonforms-detect-light
DETECTOR_SERVICE_URL_LIGHT=https://dullypdf-detector-light-xxxxx-uc.a.run.app
DETECTOR_TASKS_QUEUE_HEAVY=commonforms-detect-heavy
DETECTOR_SERVICE_URL_HEAVY=https://dullypdf-detector-heavy-xxxxx-uc.a.run.app
DETECTOR_TASKS_HEAVY_PAGE_THRESHOLD=10
DETECTOR_TASKS_SERVICE_ACCOUNT=dullypdf-backend-runtime@dullypdf-dev.iam.gserviceaccount.com
# Optional override for OIDC audience (defaults to detector URL).
DETECTOR_TASKS_AUDIENCE_LIGHT=https://dullypdf-detector-light-xxxxx-uc.a.run.app
DETECTOR_TASKS_AUDIENCE_HEAVY=https://dullypdf-detector-heavy-xxxxx-uc.a.run.app
DETECTOR_TASKS_DISPATCH_DEADLINE_SECONDS_LIGHT=900
DETECTOR_TASKS_DISPATCH_DEADLINE_SECONDS_HEAVY=1200
DETECTOR_TASKS_FORCE_IMMEDIATE=false
COMMONFORMS_MODEL=FFDNet-L
COMMONFORMS_MODEL_GCS_URI=gs://dullypdf-dev-models/commonforms/FFDNet-L.pt

# Admin override (optional; leave empty for prod-like tests)
ADMIN_TOKEN=
SANDBOX_ALLOW_ADMIN_OVERRIDE=false

# Firebase Admin
FIREBASE_PROJECT_ID=dullypdf-dev
FIREBASE_CHECK_REVOKED=true
FIREBASE_CREDENTIALS_SECRET=dullypdf-dev-firebase-admin
FIREBASE_CREDENTIALS_PROJECT=dullypdf-dev
# Firebase OAuth providers (reference only)
FIREBASE_GITHUB_CLIENT_ID=
FIREBASE_GITHUB_CLIENT_SECRET=
FIREBASE_GOOGLE_CLIENT_ID=
FIREBASE_GOOGLE_CLIENT_SECRET=
# Optional local key file fallback:
# FIREBASE_CREDENTIALS=/path/to/dullypdf-dev-service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/dullypdf-dev-service-account.json

# Storage buckets
FORMS_BUCKET=dullypdf-dev-forms
TEMPLATES_BUCKET=dullypdf-dev-templates
SANDBOX_SESSION_BUCKET=dullypdf-dev-sessions

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_SCHEMA_MAPPING_MODEL=gpt-5.2
SANDBOX_RENAME_MODEL=gpt-5.2
# OpenAI SDK client behavior (rename/remap local + workers).
OPENAI_REQUEST_TIMEOUT_SECONDS=75
OPENAI_MAX_RETRIES=1
# Worker SDK retries are separate from Cloud Tasks retries; keep this at 0 unless explicitly needed.
OPENAI_WORKER_MAX_RETRIES=0
# Optional pricing inputs for per-job USD estimates in openai_jobs/status responses.
OPENAI_PRICE_INPUT_PER_1M_USD=
OPENAI_PRICE_OUTPUT_PER_1M_USD=
OPENAI_PRICE_CACHED_INPUT_PER_1M_USD=
OPENAI_PRICE_REASONING_OUTPUT_PER_1M_USD=
BASE_OPENAI_CREDITS=10
PRO_MONTHLY_OPENAI_CREDITS=500
# Credit refund retries/reconciliation for rename/remap failures.
OPENAI_CREDIT_REFUND_MAX_ATTEMPTS=3
OPENAI_CREDIT_REFUND_RETRY_BACKOFF_MS=150
SANDBOX_OPENAI_LOG_TTL_SECONDS=2592000

# Stripe billing (dev stack / test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_REFILL_500=
STRIPE_REFILL_CREDITS=500
# Required when webhook health enforcement is enabled.
STRIPE_WEBHOOK_ENDPOINT_URL=http://localhost:8000/api/billing/webhook
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/?billing=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/?billing=cancel

# OpenAI rename worker (Cloud Tasks)
OPENAI_RENAME_MODE=tasks
OPENAI_RENAME_TASKS_PROJECT=dullypdf-dev
OPENAI_RENAME_TASKS_LOCATION=us-central1
OPENAI_RENAME_TASKS_QUEUE_LIGHT=openai-rename-light
OPENAI_RENAME_SERVICE_URL_LIGHT=https://dullypdf-openai-rename-light-xxxxx-uc.a.run.app
OPENAI_RENAME_TASKS_QUEUE_HEAVY=openai-rename-heavy
OPENAI_RENAME_SERVICE_URL_HEAVY=https://dullypdf-openai-rename-heavy-xxxxx-uc.a.run.app
OPENAI_RENAME_TASKS_HEAVY_PAGE_THRESHOLD=10
OPENAI_RENAME_TASKS_SERVICE_ACCOUNT=dullypdf-backend-runtime@dullypdf-dev.iam.gserviceaccount.com
OPENAI_RENAME_TASKS_AUDIENCE_LIGHT=https://dullypdf-openai-rename-light-xxxxx-uc.a.run.app
OPENAI_RENAME_TASKS_AUDIENCE_HEAVY=https://dullypdf-openai-rename-heavy-xxxxx-uc.a.run.app
OPENAI_RENAME_TASKS_DISPATCH_DEADLINE_SECONDS_LIGHT=600
OPENAI_RENAME_TASKS_DISPATCH_DEADLINE_SECONDS_HEAVY=900

# OpenAI schema mapping worker (Cloud Tasks)
OPENAI_REMAP_MODE=tasks
OPENAI_REMAP_TASKS_PROJECT=dullypdf-dev
OPENAI_REMAP_TASKS_LOCATION=us-central1
OPENAI_REMAP_TASKS_QUEUE_LIGHT=openai-remap-light
OPENAI_REMAP_SERVICE_URL_LIGHT=https://dullypdf-openai-remap-light-xxxxx-uc.a.run.app
OPENAI_REMAP_TASKS_QUEUE_HEAVY=openai-remap-heavy
OPENAI_REMAP_SERVICE_URL_HEAVY=https://dullypdf-openai-remap-heavy-xxxxx-uc.a.run.app
OPENAI_REMAP_TASKS_HEAVY_TAG_THRESHOLD=120
OPENAI_REMAP_TASKS_SERVICE_ACCOUNT=dullypdf-backend-runtime@dullypdf-dev.iam.gserviceaccount.com
OPENAI_REMAP_TASKS_AUDIENCE_LIGHT=https://dullypdf-openai-remap-light-xxxxx-uc.a.run.app
OPENAI_REMAP_TASKS_AUDIENCE_HEAVY=https://dullypdf-openai-remap-heavy-xxxxx-uc.a.run.app
OPENAI_REMAP_TASKS_DISPATCH_DEADLINE_SECONDS_LIGHT=420
OPENAI_REMAP_TASKS_DISPATCH_DEADLINE_SECONDS_HEAVY=600

# Best-effort worker warmup when detection is near completion.
OPENAI_PREWARM_ENABLED=true
OPENAI_PREWARM_REMAINING_PAGES=3
OPENAI_PREWARM_TIMEOUT_SECONDS=2

# Debug/logging (disabled for prod-like stack)
SANDBOX_DEBUG=false
SANDBOX_DEBUG_PASSWORD=
SANDBOX_DEBUG_FORCE=false
SANDBOX_LOG_OPENAI_RESPONSE=false
