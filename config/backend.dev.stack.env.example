# Backend (dev stack; localhost gateway + prod-style Cloud Tasks/Run topology)
ENV=dev
PORT=8000
# Force prod-topology routing and auth defaults in scripts/run-dev-stack.sh.
DEV_STACK_PROD_TOPOLOGY=true
# Dev stack bind address (default 127.0.0.1). Set to 0.0.0.0 only if needed.
DEV_STACK_BIND_ADDRESS=127.0.0.1

# Security + limits
# The backend also appends a built-in localhost/127.0.0.1 Vite range (5173-5189)
# outside production so local port bumps keep working during multi-terminal dev.
SANDBOX_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176
SANDBOX_MAX_UPLOAD_MB=50
SANDBOX_DETECT_MAX_PAGES_BASE=5
SANDBOX_DETECT_MAX_PAGES_PRO=100
SANDBOX_DETECT_MAX_PAGES_GOD=100
SANDBOX_FILLABLE_MAX_PAGES_BASE=50
SANDBOX_FILLABLE_MAX_PAGES_PRO=1000
SANDBOX_FILLABLE_MAX_PAGES_GOD=1000
SANDBOX_SIGNING_REQUESTS_MONTHLY_MAX_BASE=25
SANDBOX_SIGNING_REQUESTS_MONTHLY_MAX_PRO=10000
SANDBOX_SIGNING_REQUESTS_MONTHLY_MAX_GOD=100000
SANDBOX_SAVED_FORMS_MAX_BASE=5
SANDBOX_SAVED_FORMS_MAX_PRO=100
SANDBOX_SAVED_FORMS_MAX_GOD=100
SANDBOX_FILL_LINK_RESPONSES_MONTHLY_MAX_BASE=25
SANDBOX_FILL_LINK_RESPONSES_MONTHLY_MAX_PRO=10000
SANDBOX_FILL_LINK_RESPONSES_MONTHLY_MAX_GOD=100000
SANDBOX_SESSION_TTL_SECONDS=7200
SANDBOX_SCHEMA_TTL_SECONDS=3600
SANDBOX_SESSION_SWEEP_INTERVAL_SECONDS=300
SANDBOX_SESSION_MAX_ENTRIES=200
SANDBOX_SESSION_L2_TOUCH_SECONDS=300
SANDBOX_RATE_LIMIT_BACKEND=firestore
SANDBOX_RATE_LIMIT_COLLECTION=rate_limits
SANDBOX_DETECT_RATE_LIMIT_WINDOW_SECONDS=30
SANDBOX_DETECT_RATE_LIMIT_PER_USER=6
# scripts/run-dev-stack.sh forces this to false when DEV_STACK_PROD_TOPOLOGY=true.
SANDBOX_ENABLE_LEGACY_ENDPOINTS=false
SANDBOX_TRUST_PROXY_HEADERS=true
SANDBOX_TRUSTED_PROXY_DEPTH=1
SANDBOX_TRUSTED_HOSTS=localhost,127.0.0.1,[::1],testserver

# Contact form
CONTACT_TO_EMAIL=contact@example.com
CONTACT_FROM_EMAIL=contact@example.com
# Signing invites default to CONTACT_FROM_EMAIL when unset, but keep these
# explicit in prod-like dev so invite links use the intended public host.
SIGNING_FROM_EMAIL=contact@example.com
SIGNING_APP_ORIGIN=http://localhost:5173
SIGNING_LINK_TOKEN_SECRET=change_me_dev_signing_token_secret
SIGNING_BUCKET=dullypdf-dev-signing
# Repo default dev KMS audit key. Replace this path if you use a different GCP project.
SIGNING_AUDIT_KMS_KEY=projects/dullypdf-dev/locations/us-east4/keyRings/dullypdf-signing/cryptoKeys/signing-audit
# Optional short-lived staging tier for pre-finalization uploads. When unset the
# backend falls back to the session bucket, then FORMS_BUCKET.
# SIGNING_STAGING_BUCKET=dullypdf-dev-signing-staging
SIGNING_REQUEST_TTL_DAYS=30
SIGNING_VERIFICATION_SOURCE_TYPES=workspace,fill_link_response,uploaded_pdf
SIGNING_ARTIFACT_TOKEN_TTL_SECONDS=300
FILL_LINK_SIGNING_RESEND_COOLDOWN_SECONDS=300
# Optional best-effort server-to-server signing lifecycle webhooks.
# SIGNING_WEBHOOK_URL=http://localhost:9000/hooks/signing
# SIGNING_WEBHOOK_URLS=http://localhost:9000/hooks/signing,https://example.com/hooks/signing
# SIGNING_WEBHOOK_SECRET=change_me_dev_signing_webhook_secret
# SIGNING_WEBHOOK_TIMEOUT_SECONDS=8
# SIGNING_WEBHOOK_EVENT_TYPES=request_created,request_sent,invite_sent,opened,review_confirmed,consent_accepted,completed,link_revoked,link_reissued
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Optional Secret Manager bindings for prod-like local runs when you want to
# reuse a shared sender without storing the Gmail secret/refresh token here.
GMAIL_CLIENT_SECRET_SECRET=
GMAIL_REFRESH_TOKEN_SECRET=
GMAIL_SECRETS_PROJECT=
# Defaults to "me".
GMAIL_USER_ID=
RECAPTCHA_SITE_KEY=
# Defaults to FIREBASE_PROJECT_ID when omitted.
RECAPTCHA_PROJECT_ID=
RECAPTCHA_ALLOWED_HOSTNAMES=localhost,127.0.0.1
RECAPTCHA_MIN_SCORE=0.2
CONTACT_REQUIRE_RECAPTCHA=true
SIGNUP_REQUIRE_RECAPTCHA=true
FILL_LINK_REQUIRE_RECAPTCHA=true
FILL_LINK_TOKEN_SECRET=change_me_dev_fill_link_token_secret
FILL_LINK_VIEW_RATE_WINDOW_SECONDS=60
FILL_LINK_VIEW_RATE_PER_IP=60
FILL_LINK_SUBMIT_RATE_WINDOW_SECONDS=300
FILL_LINK_SUBMIT_RATE_PER_IP=20
FILL_LINK_DOWNLOAD_RATE_WINDOW_SECONDS=300
FILL_LINK_DOWNLOAD_RATE_PER_IP=20
FILL_LINK_MAX_ANSWER_VALUE_CHARS=500
FILL_LINK_MAX_TOTAL_ANSWER_CHARS=4000
FILL_LINK_MAX_MULTI_SELECT_VALUES=25
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
CONTACT_RATE_LIMIT_PER_IP=6
SIGNUP_RATE_LIMIT_WINDOW_SECONDS=600
SIGNUP_RATE_LIMIT_PER_IP=8

# Detector service (dev via Cloud Tasks)
# Routing modes:
#   cpu   -> CPU light + CPU heavy (current config)
#   split -> CPU light + GPU heavy
#   gpu   -> GPU light + GPU heavy
DETECTOR_ROUTING_MODE=gpu
# Legacy fallback. When DETECTOR_ROUTING_MODE is unset, true maps to gpu.
DEV_STACK_DETECTOR_GPU=false
# Optional detector service region override for CPU services.
# DETECTOR_SERVICE_REGION=us-east4
# GPU services can live in a different region than the Cloud Tasks queues.
# Set this to the region where Cloud Run L4 quota is actually available.
DETECTOR_GPU_REGION=us-east4
# Optional GPU service overrides used by split/gpu routing.
# DETECTOR_SERVICE_NAME_LIGHT_GPU=dullypdf-detector-light-gpu
# DETECTOR_SERVICE_NAME_HEAVY_GPU=dullypdf-detector-heavy-gpu
# DETECTOR_SERVICE_URL_LIGHT_GPU=https://dullypdf-detector-light-gpu-xxxxx-ue.a.run.app
# DETECTOR_SERVICE_URL_HEAVY_GPU=https://dullypdf-detector-heavy-gpu-xxxxx-ue.a.run.app
# DETECTOR_TASKS_AUDIENCE_LIGHT_GPU=https://dullypdf-detector-light-gpu-xxxxx-ue.a.run.app
# DETECTOR_TASKS_AUDIENCE_HEAVY_GPU=https://dullypdf-detector-heavy-gpu-xxxxx-ue.a.run.app
# Optional generic GPU fallback used when both profiles share one URL/audience.
# DETECTOR_SERVICE_URL_GPU=
# DETECTOR_TASKS_AUDIENCE_GPU=
# Optional deploy helper override:
# DETECTOR_DEPLOY_VARIANTS=active  # active | cpu | gpu | both
# When dev only has one GPU total, serialize all GPU detector work through the
# light/default queue so heavy jobs do not race a second queue for quota.
DETECTOR_SERIALIZE_GPU_TASKS=true
# Single-GPU Cloud Run rollouts need the stable audience so the detector deploy
# does not require a second GPU revision just to sync env-derived audiences.
DETECTOR_USE_STABLE_AUDIENCE=true
# Optional GPU-first spillover. When routing mode is gpu, light PDFs below the
# fallback threshold can move to a dedicated CPU queue/service whenever the GPU
# lane already has queued or running work recorded in Firestore.
DETECTOR_GPU_BUSY_FALLBACK_TO_CPU=false
DETECTOR_GPU_BUSY_FALLBACK_PAGE_THRESHOLD=5
DETECTOR_GPU_BUSY_ACTIVE_WINDOW_SECONDS=1800
DETECTOR_MODE=tasks
DETECTOR_TASKS_PROJECT=dullypdf-dev
DETECTOR_TASKS_LOCATION=us-east4
DETECTOR_TASKS_QUEUE=commonforms-detect-light
DETECTOR_SERVICE_URL=https://dullypdf-detector-light-xxxxx-uk.a.run.app
DETECTOR_TASKS_QUEUE_LIGHT=commonforms-detect-light
DETECTOR_SERVICE_URL_LIGHT=https://dullypdf-detector-light-xxxxx-uk.a.run.app
# Optional explicit CPU spillover queue/service used by gpu-first routing.
# DETECTOR_TASKS_QUEUE_LIGHT_CPU=commonforms-detect-light-cpu
# DETECTOR_SERVICE_URL_LIGHT_CPU=https://dullypdf-detector-light-xxxxx-uk.a.run.app
# DETECTOR_TASKS_AUDIENCE_LIGHT_CPU=https://dullypdf-detector-light-xxxxx-uk.a.run.app
DETECTOR_TASKS_QUEUE_HEAVY=commonforms-detect-heavy
DETECTOR_SERVICE_URL_HEAVY=https://dullypdf-detector-heavy-xxxxx-uk.a.run.app
DETECTOR_TASKS_HEAVY_PAGE_THRESHOLD=10
DETECTOR_TASKS_SERVICE_ACCOUNT=dullypdf-detector-caller@dullypdf-dev.iam.gserviceaccount.com
DETECTOR_RUNTIME_SERVICE_ACCOUNT=dullypdf-detector-runtime@dullypdf-dev.iam.gserviceaccount.com
# Optional override for OIDC audience (defaults to detector URL).
DETECTOR_TASKS_AUDIENCE_LIGHT=https://dullypdf-detector-light-xxxxx-uk.a.run.app
DETECTOR_TASKS_AUDIENCE_HEAVY=https://dullypdf-detector-heavy-xxxxx-uk.a.run.app
DETECTOR_TASKS_DISPATCH_DEADLINE_SECONDS_LIGHT=900
DETECTOR_TASKS_DISPATCH_DEADLINE_SECONDS_HEAVY=1200
DETECTOR_TASKS_FORCE_IMMEDIATE=false
COMMONFORMS_MODEL=FFDNet-L
COMMONFORMS_MODEL_GCS_URI=gs://dullypdf-dev-models/commonforms/FFDNet-L.pt
# GPU detector deploy defaults are capped to one instance per profile unless
# you override DETECTOR_GPU_MAX_INSTANCES_LIGHT / DETECTOR_GPU_MAX_INSTANCES_HEAVY.

# Admin override (optional; leave empty for prod-like tests)
ADMIN_TOKEN=
SANDBOX_ALLOW_ADMIN_OVERRIDE=false

# Build/deploy image registry
ARTIFACT_REGISTRY_LOCATION=us-east4

# Firebase Admin
FIREBASE_PROJECT_ID=dullypdf-dev
FIREBASE_CHECK_REVOKED=true
FIREBASE_USE_ADC=true
# ADC-backed local runs should not set FIREBASE_CREDENTIALS_SECRET /
# GOOGLE_APPLICATION_CREDENTIALS because the stack mirrors the deployed auth
# path. Keep those unset unless you intentionally disable DEV_STACK_PROD_TOPOLOGY.
# FIREBASE_CREDENTIALS_SECRET=dullypdf-dev-firebase-admin
# FIREBASE_CREDENTIALS_PROJECT=dullypdf-dev
# Firebase OAuth providers (reference only)
FIREBASE_GITHUB_CLIENT_ID=
FIREBASE_GITHUB_CLIENT_SECRET=
FIREBASE_GOOGLE_CLIENT_ID=
FIREBASE_GOOGLE_CLIENT_SECRET=
# Optional local key file fallback:
# FIREBASE_CREDENTIALS=/path/to/dullypdf-dev-service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/dullypdf-dev-service-account.json

# Storage buckets
FORMS_BUCKET=dullypdf-dev-forms
TEMPLATES_BUCKET=dullypdf-dev-templates
SANDBOX_SESSION_BUCKET=dullypdf-dev-sessions

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_SCHEMA_MAPPING_MODEL=gpt-5.2
SANDBOX_RENAME_MODEL=gpt-5.2
# OpenAI SDK client behavior (rename/remap local + workers).
OPENAI_REQUEST_TIMEOUT_SECONDS=75
OPENAI_MAX_RETRIES=1
# Worker SDK retries are separate from Cloud Tasks retries; keep this at 0 unless explicitly needed.
OPENAI_WORKER_MAX_RETRIES=0
# Optional pricing inputs for per-job USD estimates in openai_jobs/status responses.
OPENAI_PRICE_INPUT_PER_1M_USD=
OPENAI_PRICE_OUTPUT_PER_1M_USD=
OPENAI_PRICE_CACHED_INPUT_PER_1M_USD=
OPENAI_PRICE_REASONING_OUTPUT_PER_1M_USD=
BASE_OPENAI_CREDITS=10
PRO_MONTHLY_OPENAI_CREDITS=500
# Credit refund retries/reconciliation for rename/remap failures.
OPENAI_CREDIT_REFUND_MAX_ATTEMPTS=3
OPENAI_CREDIT_REFUND_RETRY_BACKOFF_MS=150
SANDBOX_OPENAI_LOG_TTL_SECONDS=2592000

# Stripe billing (dev stack / test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_REFILL_500=
STRIPE_REFILL_CREDITS=500
# Required when webhook health enforcement is enabled.
STRIPE_WEBHOOK_ENDPOINT_URL=http://localhost:8010/api/billing/webhook
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/?billing=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/?billing=cancel
STRIPE_DEV_LISTEN_ENABLED=true

# OpenAI rename+remap combined worker (Cloud Tasks)
OPENAI_RENAME_REMAP_MODE=tasks
OPENAI_RENAME_REMAP_TASKS_PROJECT=dullypdf-dev
OPENAI_RENAME_REMAP_TASKS_LOCATION=us-east4
OPENAI_RENAME_REMAP_TASKS_QUEUE=openai-rename-remap
OPENAI_RENAME_REMAP_SERVICE_URL=https://dullypdf-openai-rename-remap-xxxxx-uk.a.run.app
OPENAI_RENAME_REMAP_TASKS_SERVICE_ACCOUNT=dullypdf-openai-rename-remap-caller@dullypdf-dev.iam.gserviceaccount.com
OPENAI_RENAME_REMAP_TASKS_AUDIENCE=https://dullypdf-openai-rename-remap-xxxxx-uk.a.run.app
OPENAI_RENAME_REMAP_TASKS_DISPATCH_DEADLINE_SECONDS=900
OPENAI_RENAME_REMAP_RUNTIME_SERVICE_ACCOUNT=dullypdf-openai-rename-remap-runtime@dullypdf-dev.iam.gserviceaccount.com

# Best-effort worker warmup when detection is near completion.
OPENAI_PREWARM_ENABLED=true
OPENAI_PREWARM_REMAINING_PAGES=3
OPENAI_PREWARM_TIMEOUT_SECONDS=2

# Debug/logging (disabled for prod-like stack)
SANDBOX_DEBUG=false
SANDBOX_DEBUG_PASSWORD=
SANDBOX_DEBUG_FORCE=false
SANDBOX_LOG_OPENAI_RESPONSE=false
