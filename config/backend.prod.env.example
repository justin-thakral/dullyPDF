# Backend (prod)
ENV=prod
PORT=8000

# Security + limits
SANDBOX_CORS_ORIGINS=https://your-domain.example
SANDBOX_TRUSTED_HOSTS=your-domain.example,your-service-123456789012.us-east4.run.app
SANDBOX_MAX_UPLOAD_MB=25
SANDBOX_DETECT_MAX_PAGES_BASE=5
SANDBOX_DETECT_MAX_PAGES_PRO=100
SANDBOX_DETECT_MAX_PAGES_GOD=100
SANDBOX_FILLABLE_MAX_PAGES_BASE=50
SANDBOX_FILLABLE_MAX_PAGES_PRO=1000
SANDBOX_FILLABLE_MAX_PAGES_GOD=1000
SANDBOX_SIGNING_REQUESTS_MONTHLY_MAX_BASE=25
SANDBOX_SIGNING_REQUESTS_MONTHLY_MAX_PRO=10000
SANDBOX_SIGNING_REQUESTS_MONTHLY_MAX_GOD=100000
SANDBOX_SAVED_FORMS_MAX_BASE=5
SANDBOX_SAVED_FORMS_MAX_PRO=100
SANDBOX_SAVED_FORMS_MAX_GOD=100
SANDBOX_FILL_LINK_RESPONSES_MONTHLY_MAX_BASE=25
SANDBOX_FILL_LINK_RESPONSES_MONTHLY_MAX_PRO=10000
SANDBOX_FILL_LINK_RESPONSES_MONTHLY_MAX_GOD=100000
SANDBOX_SESSION_TTL_SECONDS=7200
SESSION_CLEANUP_GRACE_SECONDS=300
SESSION_CLEANUP_REGION=us-east4
SESSION_CLEANUP_SCHEDULER_LOCATION=us-east4
SESSION_CLEANUP_SCHEDULE="0 * * * *"
SANDBOX_SCHEMA_TTL_SECONDS=3600
SANDBOX_SESSION_SWEEP_INTERVAL_SECONDS=300
SANDBOX_SESSION_MAX_ENTRIES=50
SANDBOX_SESSION_L2_TOUCH_SECONDS=300
SANDBOX_RATE_LIMIT_BACKEND=firestore
SANDBOX_RATE_LIMIT_COLLECTION=rate_limits
SANDBOX_DETECT_RATE_LIMIT_WINDOW_SECONDS=30
SANDBOX_DETECT_RATE_LIMIT_PER_USER=6

# Contact form
CONTACT_TO_EMAIL=contact@example.com
CONTACT_FROM_EMAIL=contact@example.com
# Optional dedicated sender for signing invites. Falls back to
# CONTACT_FROM_EMAIL when left empty.
SIGNING_FROM_EMAIL=
# Optional public origin for signer links. Defaults to https://dullypdf.com
# when omitted in prod. If you set it explicitly, keep it exactly at the
# canonical origin with no path/query/fragment.
SIGNING_APP_ORIGIN=
SIGNING_REQUEST_TTL_DAYS=30
SIGNING_VERIFICATION_SOURCE_TYPES=workspace,fill_link_response,uploaded_pdf
SIGNING_ARTIFACT_TOKEN_TTL_SECONDS=300
FILL_LINK_SIGNING_RESEND_COOLDOWN_SECONDS=300
# Optional best-effort server-to-server signing lifecycle webhooks.
# SIGNING_WEBHOOK_URL=https://example.com/hooks/signing
# SIGNING_WEBHOOK_URLS=https://example.com/hooks/signing,https://backup.example.com/hooks/signing
# SIGNING_WEBHOOK_SECRET=
# SIGNING_WEBHOOK_TIMEOUT_SECONDS=8
# SIGNING_WEBHOOK_EVENT_TYPES=request_created,request_sent,invite_sent,opened,review_confirmed,consent_accepted,completed,link_revoked,link_reissued
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Optional Secret Manager bindings (used by scripts/deploy-backend.sh).
OPENAI_API_KEY_SECRET=dullypdf-prod-openai-key
# Keep admin override disabled in prod; leave ADMIN_TOKEN_SECRET empty.
ADMIN_TOKEN_SECRET=
GMAIL_CLIENT_SECRET_SECRET=
GMAIL_REFRESH_TOKEN_SECRET=
# Defaults to "me".
GMAIL_USER_ID=
RECAPTCHA_SITE_KEY=
# Defaults to FIREBASE_PROJECT_ID when omitted.
RECAPTCHA_PROJECT_ID=
RECAPTCHA_CONTACT_ACTION=contact
RECAPTCHA_SIGNUP_ACTION=signup
# Required in prod when any public reCAPTCHA gate is enabled (comma-separated, supports *.example.com).
RECAPTCHA_ALLOWED_HOSTNAMES=your-domain.example
RECAPTCHA_MIN_SCORE=0.5
CONTACT_REQUIRE_RECAPTCHA=true
SIGNUP_REQUIRE_RECAPTCHA=true
FILL_LINK_REQUIRE_RECAPTCHA=true
# Canonical public Fill By Link URLs are signed from the link id in prod.
# Store the secret in Secret Manager and bind it during deploy.
FILL_LINK_TOKEN_SECRET=
FILL_LINK_TOKEN_SECRET_SECRET=dullypdf-prod-fill-link-token-secret
FILL_LINK_VIEW_RATE_WINDOW_SECONDS=60
FILL_LINK_VIEW_RATE_PER_IP=60
FILL_LINK_SUBMIT_RATE_WINDOW_SECONDS=300
FILL_LINK_SUBMIT_RATE_PER_IP=20
FILL_LINK_DOWNLOAD_RATE_WINDOW_SECONDS=300
FILL_LINK_DOWNLOAD_RATE_PER_IP=20
FILL_LINK_MAX_ANSWER_VALUE_CHARS=500
FILL_LINK_MAX_TOTAL_ANSWER_CHARS=4000
FILL_LINK_MAX_MULTI_SELECT_VALUES=25
# Signing
# Public signing links are signed from the request id in prod.
# Generate a unique random secret that is at least 32 characters before deploy.
SIGNING_LINK_TOKEN_SECRET=
# Required in prod so audit manifests are signed by Cloud KMS instead of the
# local deterministic dev signer.
SIGNING_AUDIT_KMS_KEY=projects/dullypdf/locations/us-east4/keyRings/dullypdf-signing/cryptoKeys/signing-audit
# Optional embedded PDF digital signature. Configure exactly one identity source:
# 1) PKCS#12 bundle:
# SIGNING_PDF_P12_BASE64=
# SIGNING_PDF_P12_PASSWORD=
# or:
# SIGNING_PDF_P12_PATH=/secrets/signing/signing-cert.p12
# SIGNING_PDF_P12_PASSWORD=
# 2) Cloud KMS + X.509 certificate:
# SIGNING_PDF_KMS_KEY=projects/dullypdf/locations/us-east4/keyRings/dullypdf-signing/cryptoKeys/pdf-signing
# SIGNING_PDF_CERT_PEM=
# SIGNING_PDF_CERT_CHAIN_PEM=
# Optional RFC 3161 timestamp authority for the embedded PDF signature:
# SIGNING_PDF_TSA_URL=https://tsa.example.com
# Required dedicated bucket for immutable source PDFs and finalized signed artifacts.
SIGNING_BUCKET=dullypdf-signing
# Optional short-lived staging tier for pre-finalization uploads. When unset the
# backend falls back to the session bucket, then FORMS_BUCKET.
# SIGNING_STAGING_BUCKET=dullypdf-signing-staging
SIGNING_RETENTION_DAYS=2555
SIGNING_SESSION_TTL_SECONDS=3600
SIGNING_VIEW_RATE_WINDOW_SECONDS=60
SIGNING_VIEW_RATE_PER_IP=30
SIGNING_VIEW_RATE_GLOBAL=0
SIGNING_ACTION_RATE_WINDOW_SECONDS=300
SIGNING_ACTION_RATE_PER_IP=20
SIGNING_ACTION_RATE_GLOBAL=0
SIGNING_DOCUMENT_RATE_WINDOW_SECONDS=300
SIGNING_DOCUMENT_RATE_PER_IP=40
SIGNING_DOCUMENT_RATE_GLOBAL=0
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
CONTACT_RATE_LIMIT_PER_IP=6
# Optional global cap for public endpoints like /api/contact.
CONTACT_RATE_LIMIT_GLOBAL=30
SIGNUP_RATE_LIMIT_WINDOW_SECONDS=600
SIGNUP_RATE_LIMIT_PER_IP=8
# Optional global cap for public endpoints like /api/recaptcha/assess.
SIGNUP_RATE_LIMIT_GLOBAL=100
# Required in prod. Cloud Run reaches the app through trusted proxy headers and
# startup validation rejects false here.
SANDBOX_TRUST_PROXY_HEADERS=true
# Firebase Hosting + Cloud Run append trusted proxy hops to X-Forwarded-For.
# Keep this aligned to the deployed proxy chain so rate limiting uses the last
# untrusted client hop instead of a spoofable forwarded value.
SANDBOX_TRUSTED_PROXY_DEPTH=2

# Detector service (Cloud Tasks)
# Routing modes:
#   cpu   -> CPU light + CPU heavy
#   split -> CPU light + GPU heavy
#   gpu   -> GPU-only shared single GPU
DETECTOR_ROUTING_MODE=gpu
# Optional detector service region override for CPU services.
# DETECTOR_SERVICE_REGION=us-east4
# GPU detector services can live in a different Cloud Run region.
# DETECTOR_GPU_REGION=us-east4
# Single-GPU prod keeps both GPU profiles on the light-gpu service.
# DETECTOR_SERVICE_NAME_LIGHT_GPU=dullypdf-detector-light-gpu
# DETECTOR_SERVICE_NAME_HEAVY_GPU=dullypdf-detector-light-gpu
# Single-GPU prod recreates the GPU service during deploy because Cloud Run
# cannot stand up a second GPU revision when the project only has quota for one.
# Leave DETECTOR_SERVICE_URL* blank so deploy-backend.sh always resolves the
# live Cloud Run URL from the active service name after that recreate. The
# detector rollout itself relies on the stable audience below instead of trying
# to predict the mutable run.app hostname ahead of time.
# DETECTOR_SERVICE_URL_LIGHT_GPU=
# DETECTOR_SERVICE_URL_HEAVY_GPU=
# Stable audience keeps Cloud Tasks auth independent from the mutable run.app
# URL assigned during recreate.
DETECTOR_USE_STABLE_AUDIENCE=true
# DETECTOR_TASKS_AUDIENCE_LIGHT_GPU=https://dullypdf-detector-light-gpu.dullypdf.internal
# DETECTOR_TASKS_AUDIENCE_HEAVY_GPU=https://dullypdf-detector-light-gpu.dullypdf.internal
DETECTOR_TASKS_AUDIENCE_GPU=https://dullypdf-detector-light-gpu.dullypdf.internal
# Optional deploy helper override:
# DETECTOR_DEPLOY_VARIANTS=active  # active | cpu | gpu | both
# When prod only has one GPU total, serialize all GPU detector work through the
# light/default queue so heavy jobs do not race a second queue for quota.
DETECTOR_SERIALIZE_GPU_TASKS=true
# Prod stays GPU-only. Do not configure CPU spillover for the live deploy.
DETECTOR_GPU_BUSY_FALLBACK_TO_CPU=false
DETECTOR_GPU_BUSY_FALLBACK_PAGE_THRESHOLD=5
DETECTOR_GPU_BUSY_ACTIVE_WINDOW_SECONDS=1800
DETECTOR_MODE=tasks
DETECTOR_TASKS_PROJECT=dullypdf
DETECTOR_TASKS_LOCATION=us-east4
DETECTOR_TASKS_QUEUE=commonforms-detect-light
DETECTOR_SERVICE_URL=
DETECTOR_TASKS_QUEUE_LIGHT=commonforms-detect-light
DETECTOR_SERVICE_URL_LIGHT=
# Leave CPU spillover queue/service blank in prod so gpu routing never falls
# back to a CPU detector lane.
DETECTOR_TASKS_QUEUE_LIGHT_CPU=
DETECTOR_SERVICE_URL_LIGHT_CPU=
DETECTOR_TASKS_AUDIENCE_LIGHT_CPU=
DETECTOR_TASKS_QUEUE_HEAVY=commonforms-detect-light
DETECTOR_SERVICE_URL_HEAVY=
DETECTOR_TASKS_HEAVY_PAGE_THRESHOLD=10
DETECTOR_TASKS_SERVICE_ACCOUNT=dullypdf-detector-caller@dullypdf.iam.gserviceaccount.com
# Runtime identity for the detector Cloud Run services. Keep this distinct from
# DETECTOR_TASKS_SERVICE_ACCOUNT so task invocation and service execution do not
# share the same principal.
DETECTOR_RUNTIME_SERVICE_ACCOUNT=dullypdf-detector-runtime@dullypdf.iam.gserviceaccount.com
# Optional per-profile OIDC overrides. Leave blank when the generic GPU stable
# audience above should drive both profiles.
DETECTOR_TASKS_AUDIENCE_LIGHT=
DETECTOR_TASKS_AUDIENCE_HEAVY=
# Optional dispatch deadlines (seconds).
DETECTOR_TASKS_DISPATCH_DEADLINE_SECONDS_LIGHT=900
DETECTOR_TASKS_DISPATCH_DEADLINE_SECONDS_HEAVY=1200
COMMONFORMS_MODEL=FFDNet-L
COMMONFORMS_MODEL_GCS_URI=gs://dullypdf-models-east4/commonforms/FFDNet-L.pt
COMMONFORMS_DEVICE=cpu
COMMONFORMS_FAST=false
COMMONFORMS_WEIGHTS_CACHE_DIR=/tmp/commonforms-models
COMMONFORMS_WEIGHTS_LOCK_TIMEOUT_SECONDS=600

# Admin override (optional; keep empty in prod)
ADMIN_TOKEN=

# Cloud Run runtime identity for the main backend service. This must be the
# principal attached to the deployed service so Firebase Admin uses ADC from
# the intended least-privilege runtime identity.
#
# Prod keeps the public backend in us-east4 under the east4 service name so
# deploy scripts keep the public API, queues, and workers aligned in one region.
# Prod deploy scripts reject BACKEND_SERVICE=dullypdf-backend.
# Canonical prod Artifact Registry location and repo. Prod deploy scripts reject
# central or alternate repo overrides so every service and job resolves from the
# same east4 source of truth.
ARTIFACT_REGISTRY_LOCATION=us-east4
BACKEND_REGION=us-east4
BACKEND_SERVICE=dullypdf-backend-east4
BACKEND_RUNTIME_SERVICE_ACCOUNT=dullypdf-backend-runtime@dullypdf.iam.gserviceaccount.com
# Optional Cloud Run minimum instance override for the main backend service.
# Leave this unset to preserve the current service min instances across deploys.
# Set it explicitly when you want the deploy script to manage warm capacity.
# BACKEND_MIN_INSTANCES=0

# Firebase Admin
FIREBASE_PROJECT_ID=dullypdf
# Enforce token revocation checks in prod.
FIREBASE_CHECK_REVOKED=true
# Prod must use ADC on Cloud Run with the attached runtime service account.
# That runtime service account also needs Firebase Auth read access
# (for example roles/firebaseauth.viewer) so revocation checks can look up users.
FIREBASE_USE_ADC=true
# Do not set FIREBASE_CREDENTIALS_SECRET or GOOGLE_APPLICATION_CREDENTIALS in prod.
# Firebase Admin should initialize from the attached Cloud Run identity only.
# FIREBASE_CREDENTIALS_SECRET=
# FIREBASE_CREDENTIALS_PROJECT=dullypdf
# Firebase OAuth providers (reference only)
FIREBASE_GITHUB_CLIENT_ID=
FIREBASE_GITHUB_CLIENT_SECRET=
FIREBASE_GOOGLE_CLIENT_ID=
FIREBASE_GOOGLE_CLIENT_SECRET=
FIREBASE_GITHUB_CLIENT_SECRET_SECRET=dullypdf-prod-firebase-github-client-secret
FIREBASE_GOOGLE_CLIENT_SECRET_SECRET=dullypdf-prod-firebase-google-client-secret
# Cloud Run prod must use ADC. Leave FIREBASE_CREDENTIALS and GOOGLE_APPLICATION_CREDENTIALS unset.

# Storage buckets
FORMS_BUCKET=dullypdf-forms-east4
TEMPLATES_BUCKET=dullypdf-templates-east4
SANDBOX_SESSION_BUCKET=dullypdf-sessions-east4

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_REQUEST_TIMEOUT_SECONDS=75
OPENAI_MAX_RETRIES=1
# Worker SDK retries are separate from Cloud Tasks retries; keep this at 0 unless explicitly needed.
OPENAI_WORKER_MAX_RETRIES=0
# Optional pricing inputs for per-job USD estimates in openai_jobs/status responses.
OPENAI_PRICE_INPUT_PER_1M_USD=
OPENAI_PRICE_OUTPUT_PER_1M_USD=
OPENAI_PRICE_CACHED_INPUT_PER_1M_USD=
OPENAI_PRICE_REASONING_OUTPUT_PER_1M_USD=
OPENAI_SCHEMA_MAPPING_MODEL=gpt-5.2
SANDBOX_RENAME_MODEL=gpt-5.2
OPENAI_SCHEMA_MAX_FIELDS=200
OPENAI_TEMPLATE_MAX_FIELDS=200
OPENAI_SCHEMA_MAX_PAYLOAD_BYTES=80000
OPENAI_SCHEMA_MAX_FIELD_NAME_LEN=120
OPENAI_SCHEMA_RATE_LIMIT_WINDOW_SECONDS=60
OPENAI_SCHEMA_RATE_LIMIT_PER_USER=10
OPENAI_RENAME_RATE_LIMIT_WINDOW_SECONDS=60
OPENAI_RENAME_RATE_LIMIT_PER_USER=6
BASE_OPENAI_CREDITS=10
PRO_MONTHLY_OPENAI_CREDITS=500
# Credit refund retries/reconciliation for rename/remap failures.
OPENAI_CREDIT_REFUND_MAX_ATTEMPTS=3
OPENAI_CREDIT_REFUND_RETRY_BACKOFF_MS=150
# Duplicate task submissions within this window reuse the existing job id.
OPENAI_TASK_IDEMPOTENCY_WINDOW_SECONDS=300
SANDBOX_OPENAI_LOG_TTL_SECONDS=2592000

# Stripe billing (required for prod startup/deploy checks)
# In prod deploys, use Secret Manager bindings and leave literal values empty.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY_SECRET=
STRIPE_WEBHOOK_SECRET_SECRET=
STRIPE_PRODUCT_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_REFILL_500=
STRIPE_REFILL_CREDITS=500
STRIPE_WEBHOOK_ENDPOINT_URL=https://your-domain.example/api/billing/webhook
# Optional temporary comma-separated aliases accepted by billing health checks
# during a webhook URL migration (for example, an old Cloud Run run.app URL).
STRIPE_WEBHOOK_ENDPOINT_URL_ALIASES=
# Checkout-session idempotency bucket for duplicate create retries.
STRIPE_CHECKOUT_IDEMPOTENCY_WINDOW_SECONDS=300
# Recent processed billing ids retained per user as a bounded fallback dedupe cache.
STRIPE_MAX_PROCESSED_EVENTS=256
STRIPE_CHECKOUT_SUCCESS_URL=https://your-domain.example/?billing=success
STRIPE_CHECKOUT_CANCEL_URL=https://your-domain.example/?billing=cancel

# OpenAI rename worker (Cloud Tasks)
OPENAI_RENAME_MODE=tasks
OPENAI_RENAME_TASKS_PROJECT=dullypdf
OPENAI_RENAME_TASKS_LOCATION=us-east4
OPENAI_RENAME_TASKS_QUEUE_LIGHT=openai-rename-light
OPENAI_RENAME_SERVICE_URL_LIGHT=https://dullypdf-openai-rename-light-xxxxx-uk.a.run.app
OPENAI_RENAME_TASKS_QUEUE_HEAVY=openai-rename-heavy
OPENAI_RENAME_SERVICE_URL_HEAVY=https://dullypdf-openai-rename-heavy-xxxxx-uk.a.run.app
OPENAI_RENAME_TASKS_HEAVY_PAGE_THRESHOLD=10
OPENAI_RENAME_TASKS_SERVICE_ACCOUNT=dullypdf-openai-rename-caller@dullypdf.iam.gserviceaccount.com
OPENAI_RENAME_TASKS_AUDIENCE_LIGHT=
OPENAI_RENAME_TASKS_AUDIENCE_HEAVY=
OPENAI_RENAME_TASKS_DISPATCH_DEADLINE_SECONDS_LIGHT=600
OPENAI_RENAME_TASKS_DISPATCH_DEADLINE_SECONDS_HEAVY=900

# OpenAI schema mapping worker (Cloud Tasks)
OPENAI_REMAP_MODE=tasks
OPENAI_REMAP_TASKS_PROJECT=dullypdf
OPENAI_REMAP_TASKS_LOCATION=us-east4
OPENAI_REMAP_TASKS_QUEUE_LIGHT=openai-remap-light
OPENAI_REMAP_SERVICE_URL_LIGHT=https://dullypdf-openai-remap-light-xxxxx-uk.a.run.app
OPENAI_REMAP_TASKS_QUEUE_HEAVY=openai-remap-heavy
OPENAI_REMAP_SERVICE_URL_HEAVY=https://dullypdf-openai-remap-heavy-xxxxx-uk.a.run.app
OPENAI_REMAP_TASKS_HEAVY_TAG_THRESHOLD=120
OPENAI_REMAP_TASKS_SERVICE_ACCOUNT=dullypdf-openai-remap-caller@dullypdf.iam.gserviceaccount.com
OPENAI_REMAP_TASKS_AUDIENCE_LIGHT=
OPENAI_REMAP_TASKS_AUDIENCE_HEAVY=
OPENAI_REMAP_TASKS_DISPATCH_DEADLINE_SECONDS_LIGHT=420
OPENAI_REMAP_TASKS_DISPATCH_DEADLINE_SECONDS_HEAVY=600
# Runtime identities for the OpenAI worker Cloud Run services. Keep each one
# distinct from its matching OPENAI_*_TASKS_SERVICE_ACCOUNT caller.
OPENAI_RENAME_RUNTIME_SERVICE_ACCOUNT=dullypdf-openai-rename-runtime@dullypdf.iam.gserviceaccount.com
OPENAI_REMAP_RUNTIME_SERVICE_ACCOUNT=dullypdf-openai-remap-runtime@dullypdf.iam.gserviceaccount.com

# Best-effort worker warmup when detection is near completion.
OPENAI_PREWARM_ENABLED=true
OPENAI_PREWARM_REMAINING_PAGES=3
OPENAI_PREWARM_TIMEOUT_SECONDS=2

# Debug/logging
SANDBOX_DEBUG=false
SANDBOX_LOG_OPENAI_RESPONSE=false
