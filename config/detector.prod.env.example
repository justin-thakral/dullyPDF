# Detector service (prod)
ENV=prod
PORT=8000

# Firebase Admin (ADC recommended)
FIREBASE_PROJECT_ID=dullypdf
FIREBASE_USE_ADC=true
FIREBASE_CHECK_REVOKED=true

# Storage buckets
FORMS_BUCKET=dullypdf-forms-east4
TEMPLATES_BUCKET=dullypdf-templates-east4
SANDBOX_SESSION_BUCKET=

# Detector auth (Cloud Tasks OIDC)
DETECTOR_TASKS_AUDIENCE=https://dullypdf-detector-xxxxx-uc.a.run.app
DETECTOR_CALLER_SERVICE_ACCOUNT=dullypdf-backend-runtime@dullypdf.iam.gserviceaccount.com
DETECTOR_ALLOW_UNAUTHENTICATED=false
# Match Cloud Tasks queue max attempts (used to finalize failures on the last retry).
DETECTOR_TASKS_MAX_ATTEMPTS=5
# Optional backoff hint for Cloud Tasks retries (seconds).
DETECTOR_RETRY_AFTER_SECONDS=5

# CommonForms tuning (optional)
COMMONFORMS_MODEL=FFDNet-L
COMMONFORMS_MODEL_GCS_URI=gs://dullypdf-models-east4/commonforms/FFDNet-L.pt
COMMONFORMS_CONFIDENCE=0.3
COMMONFORMS_IMAGE_SIZE=1600
COMMONFORMS_DEVICE=cpu
COMMONFORMS_FAST=false
COMMONFORMS_MULTILINE=false
COMMONFORMS_BATCH_SIZE=4
COMMONFORMS_CONFIDENCE_GREEN=0.60
COMMONFORMS_CONFIDENCE_YELLOW=0.30
COMMONFORMS_WEIGHTS_CACHE_DIR=/tmp/commonforms-models
COMMONFORMS_WEIGHTS_LOCK_TIMEOUT_SECONDS=600
SANDBOX_DISABLE_TENSORBOARD=true

# HuggingFace model download token (recommended)
HF_TOKEN=
# HUGGINGFACE_HUB_TOKEN=
