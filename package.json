{
  "name": "dullypdf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "test": "npm run test:backend && npm run test:frontend",
    "start:fast": "npm run kill-old && node scripts/wsl_warn.js && npm run dev",
    "dev": "bash scripts/run-dev.sh",
    "dev:core": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "dev:stack": "bash scripts/run-dev-stack.sh",
    "dev:stack:stop": "bash scripts/stop-dev-stack.sh",
    "build:dev": "npm run frontend:build:dev",
    "build:prod": "npm run frontend:build:prod",
    "kill-old": "bash scripts/kill_old_processes.sh",
    "frontend:dev": "bash scripts/use-frontend-env.sh dev && cd frontend && npm run dev",
    "frontend:webp": "bash scripts/convert-webp-assets.sh",
    "frontend:build:dev": "cd frontend && npm run build:dev",
    "frontend:build:prod": "cd frontend && npm run build:prod",
    "backend:dev": "bash scripts/run-backend-dev.sh",
    "backend:prod": "bash scripts/run-backend-prod.sh",
    "clean": "python3 clean.py",
    "demo:generate-name-maps": "backend/.venv/bin/python scripts/demo/generate_demo_name_maps.py",
    "deploy": "npm run deploy:backend && npm run deploy:frontend",
    "deploy:backend": "bash scripts/deploy-backend.sh",
    "deploy:all-services": "bash scripts/deploy-all-services.sh",
    "deploy:detector-services": "bash scripts/deploy-detector-services.sh",
    "deploy:openai-workers": "bash scripts/deploy-openai-workers.sh",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "test:backend:template-api": "backend/.venv/bin/python -m pytest backend/test/unit/api/test_main_template_api_endpoints_blueprint.py backend/test/unit/api/test_main_template_api_public_blueprint.py backend/test/unit/firebase/test_template_api_endpoint_database_blueprint.py backend/test/unit/services/test_template_api_service_blueprint.py backend/test/integration/test_template_api_integration.py -q",
    "coverage:backend:template-api": "backend/.venv/bin/python -m pytest backend/test/unit/api/test_main_template_api_endpoints_blueprint.py backend/test/unit/api/test_main_template_api_public_blueprint.py backend/test/unit/firebase/test_template_api_endpoint_database_blueprint.py backend/test/unit/services/test_template_api_service_blueprint.py backend/test/integration/test_template_api_integration.py --cov=backend.api.routes.template_api --cov=backend.api.routes.template_api_public --cov=backend.services.template_api_service --cov=backend.firebaseDB.template_api_endpoint_database --cov-config=.coveragerc --cov-report=term-missing -q",
    "test:frontend:template-api": "cd frontend && npm run test -- test/unit/components/features/test_api_fill_manager_dialog.test.tsx test/unit/hooks/test_use_workspace_template_api.test.tsx",
    "test:playwright:template-api:smoke": "node frontend/test/playwright/run_template_api_manager_smoke.mjs",
    "test:playwright:template-api:ui": "node frontend/test/playwright/run_template_api_manager_real_user_flow.mjs",
    "test:playwright:template-api": "npm run test:playwright:template-api:smoke && npm run test:playwright:template-api:ui",
    "test:playwright:signing-public": "node frontend/test/playwright/run_signing_public_smoke.mjs",
    "test:qa:template-api": "npm run test:backend:template-api && npm run test:frontend:template-api && npm run test:playwright:template-api",
    "test:backend": "backend/.venv/bin/python -m pytest backend/test/unit/ --cov=backend --cov-config=.coveragerc --cov-report=term-missing -q",
    "test:frontend": "cd frontend && npm run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "concurrently": "^8.2.2"
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
