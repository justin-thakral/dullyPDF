{
  "name": "dullypdf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "stats": "bash scripts/run-stats.sh",
    "test": "npm run test:backend && npm run test:frontend",
    "start:fast": "npm run kill-old && node scripts/wsl_warn.js && npm run dev",
    "dev": "bash scripts/run-dev.sh",
    "dev:core": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "dev:stack": "bash scripts/run-dev-stack.sh",
    "dev:stack:stop": "bash scripts/stop-dev-stack.sh",
    "build:dev": "npm run frontend:build:dev",
    "build:prod": "npm run frontend:build:prod",
    "kill-old": "bash scripts/kill_old_processes.sh",
    "frontend:dev": "bash scripts/use-frontend-env.sh dev && cd frontend && npm run dev",
    "frontend:webp": "bash scripts/convert-webp-assets.sh",
    "frontend:build:dev": "cd frontend && npm run build:dev",
    "frontend:build:prod": "cd frontend && npm run build:prod",
    "backend:dev": "bash scripts/run-backend-dev.sh",
    "backend:prod": "bash scripts/run-backend-prod.sh",
    "clean": "python3 clean.py",
    "demo:generate-name-maps": "backend/.venv/bin/python scripts/demo/generate_demo_name_maps.py",
    "deploy": "npm run deploy:backend && npm run deploy:frontend",
    "deploy:backend": "bash scripts/deploy-backend.sh",
    "deploy:all-services": "bash scripts/deploy-all-services.sh",
    "deploy:detector-services": "bash scripts/deploy-detector-services.sh",
    "deploy:openai-workers": "bash scripts/deploy-openai-workers.sh",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "test:backend:template-api": "backend/.venv/bin/python -m pytest backend/test/unit/api/test_main_template_api_endpoints_blueprint.py backend/test/unit/api/test_main_template_api_public_blueprint.py backend/test/unit/firebase/test_template_api_endpoint_database_blueprint.py backend/test/unit/services/test_template_api_service_blueprint.py backend/test/integration/test_template_api_integration.py -q",
    "test:backend:template-api:integration": "backend/.venv/bin/python -m pytest backend/test/integration/test_template_api_integration.py -q",
    "coverage:backend:template-api": "backend/.venv/bin/python -m pytest backend/test/unit/api/test_main_template_api_endpoints_blueprint.py backend/test/unit/api/test_main_template_api_public_blueprint.py backend/test/unit/firebase/test_template_api_endpoint_database_blueprint.py backend/test/unit/services/test_template_api_service_blueprint.py backend/test/integration/test_template_api_integration.py --cov=backend.api.routes.template_api --cov=backend.api.routes.template_api_public --cov=backend.services.template_api_service --cov=backend.firebaseDB.template_api_endpoint_database --cov-config=.coveragerc --cov-report=term-missing -q",
    "test:frontend:template-api": "cd frontend && npm run test -- test/unit/components/features/test_api_fill_manager_dialog.test.tsx test/unit/hooks/test_use_workspace_template_api.test.tsx",
    "test:playwright:template-api:smoke": "node frontend/test/playwright/run_template_api_manager_smoke.mjs",
    "test:playwright:template-api:ui": "node frontend/test/playwright/run_template_api_manager_real_user_flow.mjs",
    "test:playwright:template-api:real": "node frontend/test/playwright/run_template_api_manager_real_user_flow.mjs",
    "test:playwright:template-api": "npm run test:playwright:template-api:real",
    "test:playwright:localhost-auth-profile": "node frontend/test/playwright/run_localhost_auth_profile_smoke.mjs",
    "test:playwright:localhost-detection": "node frontend/test/playwright/run_localhost_detection_smoke.mjs",
    "test:playwright:saved-form-snapshot:real": "node frontend/test/playwright/run_saved_form_snapshot_smoke.mjs",
    "test:playwright:fill-link-download:real": "node frontend/test/playwright/run_fill_link_download_smoke.mjs",
    "test:playwright:deployed-frontend:real": "node frontend/test/playwright/run_deployed_frontend_smoke.mjs",
    "test:playwright:openai-rename": "node frontend/test/playwright/run_openai_rename_smoke.mjs",
    "test:playwright:openai-rename-remap": "node frontend/test/playwright/run_openai_rename_remap_smoke.mjs",
    "test:playwright:downgrade-retention:real": "node frontend/test/playwright/run_downgrade_retention_real_user_flow.mjs",
    "test:playwright:downgrade-retention:cleanup:real": "node frontend/test/playwright/run_downgrade_retention_stale_cleanup.mjs",
    "test:playwright:signing-quota": "node frontend/test/playwright/run_signing_monthly_quota_smoke.mjs",
    "test:playwright:signing-public": "node frontend/test/playwright/run_signing_public_smoke.mjs",
    "test:playwright:signing-envelope": "node frontend/test/playwright/run_signing_envelope_real_flow.mjs",
    "test:playwright:signing-envelope:separate": "SIGNING_MODE=separate node frontend/test/playwright/run_signing_envelope_real_flow.mjs",
    "test:playwright:signing-envelope:parallel": "SIGNING_MODE=parallel node frontend/test/playwright/run_signing_envelope_real_flow.mjs",
    "test:playwright:signing-envelope:sequential": "SIGNING_MODE=sequential node frontend/test/playwright/run_signing_envelope_real_flow.mjs",
    "test:qa:template-api": "npm run test:backend:template-api && npm run test:frontend:template-api && npm run test:playwright:template-api",
    "test:backend": "backend/.venv/bin/python -m pytest backend/test/unit/ --cov=backend --cov-config=.coveragerc --cov-report=term-missing -q",
    "test:backend:ci": "backend/.venv/bin/python -m pytest backend/test/unit/ --ignore=backend/test/unit/scripts --ignore=backend/test/unit/config --ignore=backend/test/unit/internal_stats --cov=backend --cov-config=.coveragerc --cov-report=term-missing -q",
    "test:backend:governance": "backend/.venv/bin/python -m pytest backend/test/unit/scripts backend/test/unit/config backend/test/unit/internal_stats -q",
    "test:frontend": "cd frontend && npm run test",
    "test:frontend:ci": "cd frontend && npx vitest run --exclude test/unit/components/pages/test_blog_index_page.test.tsx --exclude test/unit/components/pages/test_blog_post_page.test.tsx --exclude test/unit/components/pages/test_feature_plan_page.test.tsx --exclude test/unit/components/pages/test_homepage.test.tsx --exclude test/unit/components/pages/test_intent_hub_page.test.tsx --exclude test/unit/components/pages/test_intent_landing_page.test.tsx --exclude test/unit/components/pages/test_legal_page.test.tsx --exclude test/unit/components/pages/test_public_not_found_page.test.tsx --exclude test/unit/components/pages/test_usage_docs_content.test.ts --exclude test/unit/components/pages/test_usage_docs_not_found_page.test.tsx --exclude test/unit/components/pages/test_usage_docs_page.test.tsx --exclude test/unit/config/test_feature_plan_pages.test.ts --exclude test/unit/config/test_intent_pages.test.ts --exclude test/unit/config/test_route_seo.test.ts --exclude test/unit/scripts/test_generate_static_html.test.ts --exclude 'test/unit/legacy/**'",
    "test:frontend:content": "cd frontend && npx vitest run test/unit/components/pages/test_blog_index_page.test.tsx test/unit/components/pages/test_blog_post_page.test.tsx test/unit/components/pages/test_feature_plan_page.test.tsx test/unit/components/pages/test_homepage.test.tsx test/unit/components/pages/test_intent_hub_page.test.tsx test/unit/components/pages/test_intent_landing_page.test.tsx test/unit/components/pages/test_legal_page.test.tsx test/unit/components/pages/test_public_not_found_page.test.tsx test/unit/components/pages/test_usage_docs_content.test.ts test/unit/components/pages/test_usage_docs_not_found_page.test.tsx test/unit/components/pages/test_usage_docs_page.test.tsx test/unit/config/test_feature_plan_pages.test.ts test/unit/config/test_intent_pages.test.ts test/unit/config/test_route_seo.test.ts test/unit/scripts/test_generate_static_html.test.ts test/unit/legacy"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "concurrently": "^8.2.2"
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
